# =============================================================================
# .env.example — Environment Variable Template
# =============================================================================
# SETUP INSTRUCTIONS:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in values below (remove the # in front to activate a setting)
#   3. NEVER commit your real .env to Git — it is in .gitignore
# =============================================================================

# --- LLM Provider ---
# Options: "groq" (cloud, free tier), "ollama" (local, free), "openai" (paid)
LLM_PROVIDER=groq

# --- Groq settings (used when LLM_PROVIDER=groq) ---
# Get your FREE API key at: https://console.groq.com
# Fast inference — no local GPU needed, generous free tier.
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama3-8b-8192
# Other Groq model options:
#   GROQ_MODEL=llama3-70b-8192       (smarter, still free)
#   GROQ_MODEL=mixtral-8x7b-32768    (32k context, great for long docs)
#   GROQ_MODEL=gemma2-9b-it          (Google Gemma 2)

# --- Ollama settings (used when LLM_PROVIDER=ollama) ---
# Requires Ollama installed locally: https://ollama.com
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# --- OpenAI settings (used when LLM_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Embedding model ---
# Default: fast lightweight model (80MB, 384-dim vectors)
# Alternative: BAAI/bge-large-en (higher quality, slower, 1.3GB)
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# --- Retrieval settings ---
# Number of chunks returned per query (assignment: 3–5)
TOP_K_RESULTS=4
# Minimum relevance score to include a chunk (0.0 – 1.0)
SIMILARITY_THRESHOLD=0.3

# --- ChromaDB settings ---
CHROMA_COLLECTION_NAME=rag_knowledge_base

# --- LLM output ---
# 0.0 = fully deterministic, 1.0 = creative. Keep low for factual RAG.
LLM_TEMPERATURE=0.1
