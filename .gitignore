# =============================================================================
# .gitignore — Files and folders to exclude from Git
# =============================================================================

# --- Environment & secrets (NEVER commit these) ---
.env

# --- Python runtime ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# --- Virtual environments ---
venv/
.venv/
env/
.env/

# --- Vector store (large binary files, rebuilt via --ingest) ---
vector_store/

# --- Raw data (often large; document in sources.md instead) ---
data/raw/

# --- IDE & OS artifacts ---
.vscode/
.idea/
*.DS_Store
Thumbs.db
*.swp
*.swo

# --- Jupyter notebooks checkpoints ---
.ipynb_checkpoints/

# --- Model cache (downloaded by sentence-transformers/HuggingFace) ---
.cache/
models/

.streamlit/secrets.toml